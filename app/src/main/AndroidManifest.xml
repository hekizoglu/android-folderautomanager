<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- CRITICAL: Query all installed packages (Android 11+) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Access package visibility for app enumeration -->
    <uses-permission android:name="android.permission.GET_INSTALLED_PACKAGES" />

    <!-- Request shortcut creation (for folder assignment) -->
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />
    <uses-permission android:name="android.permission.CREATE_SHORTCUT" />

    <!-- Internet for Google Drive sync -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage access for backup/restore -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- Google Drive specific -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <application
        android:name=".AppOrganizerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppOrganizer"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33">

        <activity
            android:name=".presentation.ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AppOrganizer"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Service for background backup sync -->
        <service
            android:name=".data.remote.BackupSyncService"
            android:enabled="true"
            android:exported="false" />

        <!-- Broadcast receiver for package change events -->
        <receiver
            android:name=".presentation.receivers.PackageChangeReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_CHANGED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>

    <!-- Query specific apps for shortcuts and functionality -->
    <queries>
        <!-- Google Drive for backup -->
        <package android:name="com.google.android.apps.drive" />
        <package android:name="com.google.android.gms" />

        <!-- Launchers for folder creation -->
        <package android:name="com.android.launcher" />
        <package android:name="com.android.launcher2" />
        <package android:name="com.android.launcher3" />
        <package android:name="com.sec.android.app.launcher" />
        <package android:name="com.miui.home" />
        <package android:name="org.adw.launcher" />
        <package android:name="org.adwfreak.launcher" />
        <package android:name="com.teslacoilsw.launcher" />

        <!-- Intent queries for general functionality -->
        <intent>
            <action android:name="android.intent.action.CREATE_SHORTCUT" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

</manifest>
