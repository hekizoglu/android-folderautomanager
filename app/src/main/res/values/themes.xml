<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AppOrganizer" parent="Theme.MaterialComponents.DayNight.NoActionBar" />

    <!-- Splash Screen teması -->
    <style name="Theme.AppOrganizer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#00897B</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AppOrganizer</item>
        <!-- DeviceDefault gri baslik cubugu guvencesi — postSplashScreenTheme gec uygulansa bile baslik gorunmez (D234) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Launcher teması — sistem duvar kağıdını arka planda gösterir -->
    <style name="Theme.AppOrganizer.Launcher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
