<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <exclude domain="file" path="cache" />
        <exclude domain="file" path="logs" />
        <exclude domain="file" path="temp" />
        <exclude domain="file" path="crash_log.txt" />
        <exclude domain="sharedpref" path="deepseek_prefs.xml" />
        <!-- Widget ID'leri cihaza/kuruluma ozeldir (AppWidgetManager tarafindan uretilir) — baska
             cihazda veya yeniden kurulumda gecersizdir (F21, D261 denetimi). -->
        <exclude domain="sharedpref" path="widget_prefs.xml" />
        <!-- Gizlilik: bildirim metni (apps.notificationText) icerebilen Room DB'si bulut yedeğine dahil edilmez -->
        <exclude domain="database" path="app_organizer_db" />
        <exclude domain="database" path="app_organizer_db-wal" />
        <exclude domain="database" path="app_organizer_db-shm" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="deepseek_prefs.xml" />
        <exclude domain="sharedpref" path="widget_prefs.xml" />
        <!-- Gizlilik: bildirim metni (apps.notificationText) icerebilen Room DB'si cihazlar arasi aktarima dahil edilmez -->
        <exclude domain="database" path="app_organizer_db" />
        <exclude domain="database" path="app_organizer_db-wal" />
        <exclude domain="database" path="app_organizer_db-shm" />
    </device-transfer>
</data-extraction-rules>
